APP_NAME=FinaryAPI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://api-finary.my.id

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=finary
# DB_USERNAME=root
